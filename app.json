{
  "expo": {
    "name": "Rally",
    "slug": "rally",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "rally",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.rallyapp.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D85A30",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "io.rallyapp.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "rally",
          "organization": "rally"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D85A30"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Rally uses your location to show your group where everyone is during the trip.",
          "locationWhenInUsePermission": "Rally uses your location to show your group where everyone is during the trip."
        }
      ],
      "expo-secure-store",
      "expo-iap",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "36b0541b-e001-4129-af1b-11b5ee16bc58"
      },
      "router": {}
    }
  }
}
