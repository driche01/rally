{
  "name": "rally",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "typescript": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.5.0",
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/query-async-storage-persister": "^5.100.7",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.100.7",
    "expo": "~55.0.5",
    "expo-auth-session": "~55.0.8",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-contacts": "~55.0.13",
    "expo-dev-client": "~55.0.28",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-iap": "^3.4.10",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.7",
    "expo-location": "^55.1.4",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.2",
    "posthog-react-native": "^4.37.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "jest": "^30.3.0",
    "jest-expo": "~55.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "./jest.env.js",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.{ts,tsx}"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|nativewind|posthog-react-native))"
    ]
  },
  "private": true
}
