# Supabase Edge Function secrets for the Rally SMS agent.
# Copy to .env for local dev (supabase functions serve --env-file=.env)
# or set in production via:
#   npx supabase secrets set KEY=VALUE --project-ref <project-ref>

# ─── Core SMS pipeline ──────────────────────────────────────────────────────
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Telemetry (optional, no-op when unset) ─────────────────────────────────
# Sentry DSN — full dsn URL from Project Settings → Client Keys
SENTRY_DSN=

# PostHog server-side project API key (phc_... prefix). Distinct from the
# EXPO_PUBLIC_POSTHOG_KEY used by the React Native app.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── Environment label (optional) ───────────────────────────────────────────
# Used for tagging Sentry events; defaults to "production" when unset.
SUPABASE_ENV=production
